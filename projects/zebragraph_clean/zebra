    "diffusion":   "ambiguity_diffusion",
    "rhetoric":    "rhetorical_voice",
    "rhetorical":  "rhetorical_voice",
    "voice":       "rhetorical_voice",
    "concepts":    "concept_map",
    "concept":     "concept_map",
    "procedural":  "procedural_transform",
    "transform":   "procedural_transform",
    "timeline":    "timeline_causality",
    "causality":   "timeline_causality",
    "characters":  "character_state",
    "character":   "character_state",
    "sonic":       "sonic_mapping",
    "sound":       "sonic_mapping",
    "summary":     "structural_summary",
    "structural":  "structural_summary",
}

RENDER_ALIASES = {
    "diagram":      "diagrammatic_structure",
    "diagrammatic": "diagrammatic_structure",
    "diffusion":    "ambiguity_diffusion",
    "ambiguity":    "ambiguity_diffusion",
    "concept":      "concept_diffusion",
    "concepts":     "concept_diffusion",
    "constraints":  "constraint_dynamics",
    "constraint":   "constraint_dynamics",
    "dynamics":     "constraint_dynamics",
    "timeline":     "timeline_causality",
    "causality":    "timeline_causality",
    "characters":   "character_state",
    "character":    "character_state",
    "sonic":        "sonic_mapping",
    "sound":        "sonic_mapping",
    "film":         "narrative_film",
    "narrative":    "narrative_film",
    "summary":      "structural_summary",
    "structural":   "structural_summary",
}

ALL_PROJECTIONS = [
    "narrative_film",
    "diagrammatic_structure",
    "ambiguity_diffusion",
    "rhetorical_voice",
