        "--existing-graph",  str(existing),
        "--output-dir",      str(recycled_dir),
        "--model",           model,
        "--run-scripts",
    )


def cmd_agent(args):
    """zebra agent <cmd> [args] — local capability-aware scheduler"""
    # Pass remaining argv to the agent's own argparser
    import sys as _sys
    agent_args = []
    if args.target:
        agent_args.append(args.target)
    # Collect any extra positional args the user may have typed after 'agent'
    # (These arrive as sys.argv tail beyond what argparse consumed)
    _sys.path.insert(0, str(ROOT / "src"))
    from agent.agent import main as agent_main
    # Rebuild argv for the agent subparser from what we have
    idx = None
    for i, a in enumerate(_sys.argv):
        if a == "agent":
            idx = i
            break
    if idx is not None:
        agent_argv = _sys.argv[idx+1:]
    else:
        agent_argv = agent_args
    agent_main(agent_argv)

def latest_stem_wiki() -> str:
    """Return the most recently modified stem under data/wiki/."""
    wiki_dir = ROOT / "data" / "wiki"
    if not wiki_dir.exists():
        print("zebra: no wiki data found — run 'zebra crawl <repo>' first")
        sys.exit(1)
    stems = sorted(
        (p for p in wiki_dir.iterdir() if p.is_dir() and (p / "corpus_graph.json").exists()),
        key=lambda p: p.stat().st_mtime, reverse=True,
    )
    if not stems:
        print("zebra: no corpus_graph.json found — run 'zebra crawl <repo>' first")
        sys.exit(1)
    return stems[0].name


# ── argument parsing ──────────────────────────────────────────────────────────

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="zebra",
        description="zebragraph — predation-resistant text analysis engine",
        add_help=True,
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    p.add_argument("verb", choices=["extract", "project", "render", "simulate", "crawl", "wiki", "search", "diff", "person", "serve", "scripts", "recycle", "agent"],
                   help="command verb")
    p.add_argument("target", nargs="?", default=None,
                   help="file path (extract) or name/all (project/render/simulate)")
    p.add_argument("--stem", default=None,
                   help="override stem (default: derived from last extracted file)")
    p.add_argument("--model", default=None,
                   help="Ollama model name (default: granite4 or $MODEL env var)")
    p.add_argument("--title", default=None,
                   help="Site title for zebra wiki (default: derived from stem)")
    p.add_argument("--after", default=None,
                   help="Second graph path for zebra diff")
    p.add_argument("--port", type=int, default=8080,
                   help="Port for zebra serve (default: 8080)")
    p.add_argument("--mode", default="full",
                   choices=["full","entity","claim","theme"],
                   help="Search mode for zebra search (default: full)")
    return p


VERBS = {
    "extract":  cmd_extract,
    "project":  cmd_project,
    "render":   cmd_render,
    "simulate": cmd_simulate,
    "crawl":    cmd_crawl,
    "wiki":     cmd_wiki,
    "search":   cmd_search,
    "diff":     cmd_diff,
    "person":   cmd_person,
    "serve":    cmd_serve,
    "scripts":  cmd_scripts,
    "recycle":  cmd_recycle,
    "agent":    cmd_agent,
}


def main():
    # Change to repo root so relative data/ paths always resolve correctly
    os.chdir(ROOT)

    parser = build_parser()
    if len(sys.argv) < 2:
        parser.print_help()
        sys.exit(0)

    args = parser.parse_args()
    VERBS[args.verb](args)


if __name__ == "__main__":
    main()
