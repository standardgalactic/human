def cmd_scripts(args):
    """zebra scripts [--stem STEM] — generate task scripts from projections"""
    stem = args.stem or latest_stem()
    model = args.model or os.environ.get("MODEL", "granite4")

    # Prefer corpus graph over single-doc graph
    wiki_graph  = ROOT / "data" / "wiki"  / stem / "corpus_graph.json"
    canon_graph = ROOT / "data" / "canonical" / stem / "graph.json"
    gpath = wiki_graph if wiki_graph.exists() else canon_graph

    if not gpath.exists():
        print(f"zebra: no graph found for stem '{stem}' — run zebra extract or zebra crawl first")
        sys.exit(1)

    # Build all projections first if not present
    proj_dir = ROOT / "data" / "projections" / stem
    proj_dir.mkdir(parents=True, exist_ok=True)

    for proj_name in [
        "narrative_film", "diagrammatic_structure", "ambiguity_diffusion",
        "timeline_causality", "structural_summary", "concept_map",
        "rhetorical_voice", "procedural_transform", "character_state",
        "sonic_mapping",
    ]:
        out = proj_dir / f"{proj_name}.json"
        if not out.exists():
            script = ROOT / "projections" / f"build_{proj_name}.py"
            if script.exists():
                with open(out, "w") as f:
                    run([sys.executable, str(script), str(gpath)], stdout=f)

    scripts_dir = ROOT / "data" / "scripts" / stem
    scripts_dir.mkdir(parents=True, exist_ok=True)

    print(f"zebra scripts  →  {scripts_dir}  (stem={stem})")
    python(
        ROOT / "src" / "generate_scripts.py",
        "--projections-dir", str(proj_dir),
        "--graph",           str(gpath),
        "--output-dir",      str(scripts_dir),
    )
    print(f"\n  manifest: {scripts_dir}/manifest.json")
    print(f"  next:     python3 -m app.workers.ingest --project-slug {stem} "
          f"--scripts-dir {scripts_dir} --graph-path {gpath}")


