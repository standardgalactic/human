    wiki_dir          = ROOT / "data" / "wiki" / stem
    corpus_graph_path = wiki_dir / "corpus_graph.json"

    if not corpus_graph_path.exists():
        print(f"zebra wiki: no corpus graph found at {corpus_graph_path}")
        print(f"  run: zebra crawl <repo_dir> --stem {stem}")
        sys.exit(1)

    print(f"zebra wiki  →  {wiki_dir}  (title='{title}')")

    # 1. Generate articles for all themes
    python(
        ROOT / "wiki" / "generate_articles.py",
        "--corpus-graph", str(corpus_graph_path),
        "--wiki-dir",     str(wiki_dir),
        "--model",        model,
    )

    # 2. Assemble static site
    python(
        ROOT / "wiki" / "assemble_site.py",
        "--wiki-dir", str(wiki_dir),
        "--title",    title,
    )

    site_dir = wiki_dir / "site"
    print(f"\nzebra: site assembled → {site_dir}/")
    print(f"  open: {site_dir}/index.html")
    print(f"  or:   python3 -m http.server 8080 --directory {site_dir}")


def cmd_search(args):
    """zebra search <query> [--stem STEM] [--mode entity|claim|theme|full]"""
    if not args.target:
        print("zebra search: query required")
        sys.exit(1)

    stem = args.stem or latest_stem()

    # Prefer corpus graph if it exists, fall back to single-doc graph
    wiki_graph  = ROOT / "data" / "wiki"  / stem / "corpus_graph.json"
    canon_graph = ROOT / "data" / "canonical" / stem / "graph.json"

    if wiki_graph.exists():
        gpath = wiki_graph
    elif canon_graph.exists():
        gpath = canon_graph
    else:
        print(f"zebra: no graph found for stem '{stem}'")
        sys.exit(1)

    mode = getattr(args, "mode", None) or "full"
    python(
        ROOT / "src" / "search_corpus.py",
        "--graph", str(gpath),
        "--mode",  mode,
        "--query", args.target,
    )


def cmd_diff(args):
    """zebra diff <before_graph> <after_graph>"""
