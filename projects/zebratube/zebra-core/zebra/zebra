        print("zebra diff: before-graph path required as target")
        sys.exit(1)
    if not args.after:
        print("zebra diff: --after <graph> required")
        sys.exit(1)

    (ROOT / "data" / "diffs").mkdir(parents=True, exist_ok=True)
    import re as _re
    slug = _re.sub(r"[^\w]", "_", f"{Path(args.target).stem}_{Path(args.after).stem}")
    out  = ROOT / "data" / "diffs" / f"{slug}.json"

    python(
        ROOT / "src" / "diff_graphs.py",
        "--before", args.target,
        "--after",  args.after,
        "--output", str(out),
        "--human",
    )


